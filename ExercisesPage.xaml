<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WeightRecall.ExercisesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:WeightRecall.Models"
    xmlns:viewmodels="clr-namespace:WeightRecall.ViewModels"
    Title="Daily Routine"
    x:DataType="viewmodels:ExercisesViewModel"
>
    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding ShowAddRoutineCommand}" Text="+" />
    </ContentPage.ToolbarItems>

    <Grid BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">
        <!--  Main List View  -->
        <VerticalStackLayout Padding="10" Spacing="10">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,0,0,10">
                <Button
                    BorderColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    BorderWidth="1"
                    Text="WeightRecall"
                    Clicked="OnGoToWeightRecallClicked"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=Black}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    WidthRequest="150"
                    HeightRequest="40"
                />
                <Button
                    Text="Exercises"
                    Clicked="OnGoToExercisesClicked"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    TextColor="{AppThemeBinding Light=White, Dark=Black}"
                    WidthRequest="150"
                    HeightRequest="40"
                />
            </HorizontalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Label
                    Text="Showing Routine for:"
                    VerticalTextAlignment="Center"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                />
                <Picker
                    Title="Select Day"
                    ItemsSource="{Binding AvailableDays}"
                    SelectedItem="{Binding SelectedDay}"
                    WidthRequest="150"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                />
            </HorizontalStackLayout>

            <Line
                HorizontalOptions="Fill"
                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
            />

            <CollectionView ItemsSource="{Binding RoutineItems}">
                <CollectionView.EmptyView>
                    <Label
                        FontAttributes="Italic"
                        HorizontalOptions="Center"
                        Text="No exercises for today"
                        VerticalOptions="Center"
                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                    />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:RoutineItem">
                        <Border
                            Margin="0,5"
                            Padding="10"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                        >
                            <!--  Round corners if needed: StrokeShape="RoundRectangle 10"  -->
                            <Grid ColumnDefinitions="*, Auto, Auto, Auto" ColumnSpacing="5">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label
                                        FontAttributes="Bold"
                                        FontSize="18"
                                        Text="{Binding ExerciseName}"
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    />
                                    <Label
                                        FontSize="14"
                                        Text="{Binding Order, StringFormat='Sequence Order: {0}'}"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                    />
                                </VerticalStackLayout>
                                <Button
                                    Grid.Column="1"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ExercisesViewModel}}, Path=ViewProgressCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    Text="📈"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    WidthRequest="40"
                                />
                                <Button
                                    Grid.Column="2"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray700}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ExercisesViewModel}}, Path=ShowEditRoutineCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    Text="✎"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    WidthRequest="40"
                                />
                                <Button
                                    Grid.Column="3"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:ExercisesViewModel}}, Path=DeleteRoutineItemCommand}"
                                    CommandParameter="{Binding .}"
                                    CornerRadius="10"
                                    HeightRequest="40"
                                    Text="✕"
                                    TextColor="Red"
                                    WidthRequest="40"
                                />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>

        <!--  Add Exercise Popup Overlay  -->
        <Grid Padding="20" BackgroundColor="#80000000" IsVisible="{Binding IsAddingRoutine}">
            <Border
                BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray950}}"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 10"
                VerticalOptions="Center"
                WidthRequest="300"
            >
                <VerticalStackLayout Padding="20" Spacing="15">
                    <Label
                        FontAttributes="Bold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Text="{Binding PopupTitle}"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    />

                    <Border
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        Padding="10,0"
                    >
                        <Entry
                            Placeholder="Exercise Name"
                            Text="{Binding NewExerciseName}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            BackgroundColor="Transparent"
                            HeightRequest="44"
                        />
                    </Border>

                    <Border
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        Padding="10,0"
                    >
                        <Picker
                            Title="Select Day"
                            ItemsSource="{Binding AvailableDays}"
                            SelectedItem="{Binding SelectedDay}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            BackgroundColor="Transparent"
                            HeightRequest="44"
                        />
                    </Border>

                    <Border
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        Padding="10,0"
                    >
                        <Entry
                            Keyboard="Numeric"
                            Placeholder="Order"
                            Text="{Binding NewOrder}"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                            BackgroundColor="Transparent"
                            HeightRequest="44"
                        />
                    </Border>

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Button
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            Command="{Binding HideAddRoutineCommand}"
                            Text="Cancel"
                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        />
                        <Button
                            Command="{Binding SaveRoutineCommand}"
                            Text="{Binding PopupButtonText}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                            TextColor="{AppThemeBinding Light=White, Dark=Black}"
                        />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <ActivityIndicator
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
        />
    </Grid>
</ContentPage>
