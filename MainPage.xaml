<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WeightRecall.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:WeightRecall.Models"
    xmlns:viewmodels="clr-namespace:WeightRecall.ViewModels"
    Title="WeightRecall"
    x:DataType="viewmodels:MainViewModel">

    <Grid VerticalOptions="FillAndExpand">
        <VerticalStackLayout
            Padding="30"
            HorizontalOptions="Center"
            Spacing="20"
            VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="32"
                HorizontalOptions="Center"
                Text="Welcome to WeightRecall" />

            <Label
                FontSize="18"
                HorizontalOptions="Center"
                Text="Track your progress and manage your routines." />

            <Button
                Clicked="OnGoToExercisesClicked"
                HorizontalOptions="Center"
                Text="Go to Exercises" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
