<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="WeightRecall.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:WeightRecall.Views"
    Title="WeightRecall"
    FlyoutBehavior="Disabled"
>
    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Margin="10,0">
            <Label
                Text="WeightRecall"
                VerticalOptions="Center"
                FontAttributes="Bold"
                FontSize="18"
            />
            <Button
                Grid.Column="1"
                Text="⚙"
                FontSize="20"
                BackgroundColor="Transparent"
                TextColor="White"
                BorderWidth="0"
                Padding="8,0"
                Clicked="OnSettingsClicked"
                VerticalOptions="Center"
            />
        </Grid>
    </Shell.TitleView>

    <ShellContent Title="Home" ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />

    <ShellContent
        Title="Exercises"
        ContentTemplate="{DataTemplate views:ExercisesPage}"
        Route="ExercisesPage"
    />
</Shell>
