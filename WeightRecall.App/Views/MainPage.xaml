<?xml version="1.0" encoding="utf-8" ?>
<!-- Main page for daily workout logging and weekly navigation -->
<ContentPage
    x:Class="WeightRecall.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:WeightRecall.Models;assembly=WeightRecall.Core"
    xmlns:viewmodels="clr-namespace:WeightRecall.ViewModels"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    Title="WeightRecall"
    x:DataType="viewmodels:MainViewModel"
>
    <Grid
        RowDefinitions="Auto, *, Auto"
        VerticalOptions="Fill"
        BackgroundColor="{AppThemeBinding Light=White, Dark=Black}"
    >
        <VerticalStackLayout Grid.Row="0" Padding="10" Spacing="5">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5" Margin="0,0,0,10">
                <Button
                    Text="WeightRecall"
                    Clicked="OnGoToWeightRecallClicked"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    TextColor="{AppThemeBinding Light=White, Dark=Black}"
                    WidthRequest="150"
                    HeightRequest="40"
                />
                <Button
                    BorderColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    BorderWidth="1"
                    Text="Exercises"
                    Clicked="OnGoToExercisesClicked"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=Black}"
                    TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    WidthRequest="150"
                    HeightRequest="40"
                />
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="Auto, *, Auto" HorizontalOptions="Fill">
                <Button
                    Grid.Column="0"
                    Text="&lt;"
                    Command="{Binding PreviousWeekCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="20"
                    Padding="10,0"
                    VerticalOptions="Center"
                />

                <CollectionView
                    Grid.Column="1"
                    ItemsSource="{Binding WeekDays}"
                    ItemsLayout="HorizontalList"
                    HeightRequest="60"
                    HorizontalOptions="Fill"
                >
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="sys:DateTime">
                            <Border
                                Margin="2"
                                Padding="8,5"
                                WidthRequest="45"
                                StrokeShape="RoundRectangle 10"
                                BackgroundColor="Transparent"
                            >
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=SelectDateCommand}"
                                        CommandParameter="{Binding .}"
                                    />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="0" VerticalOptions="Center">
                                    <Label
                                        Text="{Binding StringFormat='{0:ddd}'}"
                                        FontSize="10"
                                        HorizontalOptions="Center"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                    />
                                    <Label
                                        Text="{Binding StringFormat='{0:dd}'}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center"
                                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                    />
                                    <Label
                                        Text="{Binding StringFormat='{0:MMM}'}"
                                        FontSize="8"
                                        HorizontalOptions="Center"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                    />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button
                    Grid.Column="2"
                    Text="&gt;"
                    Command="{Binding NextWeekCommand}"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                    FontSize="20"
                    Padding="10,0"
                    VerticalOptions="Center"
                />
            </Grid>

            <Label
                Text="{Binding SelectedDate, StringFormat='{0:D}'}"
                HorizontalOptions="Center"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                Margin="0,10,0,0"
            />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding TodayExercises}" Margin="20,0">
            <CollectionView.EmptyView>
                <Label
                    Text="No exercises scheduled for today."
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    FontAttributes="Italic"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:WorkoutLog">
                    <Border
                        Margin="0,5"
                        Padding="15"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray800}}"
                    >
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
                            <VerticalStackLayout Grid.Column="0" Grid.Row="0">
                                <Label
                                    Text="{Binding ExerciseName}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                />
                                <Label
                                    Text="{Binding PreviousDescription}"
                                    FontSize="12"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                    FontAttributes="Italic"
                                />
                            </VerticalStackLayout>

                            <HorizontalStackLayout Grid.Column="1" Grid.Row="0" Spacing="5">
                                <Button
                                    Text="📈"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=ViewProgressCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="Transparent"
                                    TextColor="#512BD4"
                                    FontSize="14"
                                />
                                <Button
                                    Text="✕"
                                    TextColor="Red"
                                    BackgroundColor="Transparent"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=DeleteLogCommand}"
                                    CommandParameter="{Binding .}"
                                />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout
                                Grid.Column="0"
                                Grid.Row="1"
                                Grid.ColumnSpan="2"
                                Spacing="15"
                                Margin="0,5,0,0"
                                VerticalOptions="Center"
                            >
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label
                                        Text="Weight:"
                                        VerticalOptions="Center"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                        FontAttributes="Bold"
                                    />
                                    <Border
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray950}}"
                                    >
                                        <Entry
                                            Text="{Binding Weight}"
                                            Keyboard="Numeric"
                                            WidthRequest="70"
                                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                            BackgroundColor="Transparent"
                                            HeightRequest="40"
                                        />
                                    </Border>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label
                                        Text="Sets:"
                                        VerticalOptions="Center"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                        FontAttributes="Bold"
                                    />
                                    <Border
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray950}}"
                                    >
                                        <Entry
                                            Text="{Binding Sets}"
                                            Keyboard="Numeric"
                                            WidthRequest="50"
                                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                            BackgroundColor="Transparent"
                                            HeightRequest="40"
                                        />
                                    </Border>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5" VerticalOptions="Center">
                                    <Label
                                        Text="Reps:"
                                        VerticalOptions="Center"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                                        FontAttributes="Bold"
                                    />
                                    <Border
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray950}}"
                                    >
                                        <Entry
                                            Text="{Binding Reps}"
                                            Keyboard="Numeric"
                                            WidthRequest="50"
                                            TextColor="{AppThemeBinding Light=Black, Dark=White}"
                                            BackgroundColor="Transparent"
                                            HeightRequest="40"
                                        />
                                    </Border>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Padding="20" Spacing="10">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                <Button
                    Command="{Binding SaveLogsCommand}"
                    Text="Save Changes"
                    WidthRequest="200"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    TextColor="{AppThemeBinding Light=White, Dark=Black}"
                />
                <Button
                    Command="{Binding GoToTodayCommand}"
                    Text="Today"
                    WidthRequest="90"
                    IsVisible="{Binding IsNotToday}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"
                    TextColor="{AppThemeBinding Light=White, Dark=Black}"
                />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <ActivityIndicator
            Grid.RowSpan="3"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
        />
    </Grid>
</ContentPage>
