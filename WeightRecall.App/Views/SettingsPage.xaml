<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="WeightRecall.Views.SettingsPage"
>
    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Grid
            Grid.Row="0"
            ColumnDefinitions="*, Auto"
            BackgroundColor="{StaticResource Primary}"
            Padding="16,12"
        >
            <Label
                Text="Settings"
                TextColor="White"
                FontSize="18"
                FontAttributes="Bold"
                VerticalOptions="Center"
            />
            <Button
                Grid.Column="1"
                Text="✕"
                BackgroundColor="Transparent"
                TextColor="White"
                FontSize="16"
                BorderWidth="0"
                Padding="10,4"
                Clicked="OnCloseClicked"
                VerticalOptions="Center"
            />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,20" Spacing="24">
                <!-- Notifications section -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="Notifications" FontSize="16" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Daily reminders" VerticalOptions="Center" />
                        <Switch
                            x:Name="NotificationSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"
                        />
                    </Grid>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                <!-- Database section -->
                <VerticalStackLayout Spacing="12">
                    <Label Text="Database" FontSize="16" FontAttributes="Bold" />
                    <Button Text="Export Data" Clicked="OnExportClicked" HorizontalOptions="Fill" />
                    <Button Text="Import Data" Clicked="OnImportClicked" HorizontalOptions="Fill" />
                    <Label
                        Text="Export as .db3, .json, or .txt. Import replaces all current data."
                        FontSize="12"
                        TextColor="{StaticResource Gray400}"
                        HorizontalTextAlignment="Center"
                    />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
